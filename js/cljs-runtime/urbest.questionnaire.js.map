;; ── State ─────────────────────────────────────────────────────────────────────
(defonce state
  (r/atom {:step        :welcome  ;; :welcome :types :questions :summary
           :types       #{}
           :answers     {}
           :section-idx 0}))

;; ── Helpers ──────────────────────────────────────────────────────────────────
(defn type-by-id [id]
  (first (filter #(= (:id %) id) equipment-types)))

(defn visible-specific-sections [types]
  (filter #(types (:for %)) specific-sections))

(defn all-visible-sections [types]
  (concat common-sections (visible-specific-sections types)))

(defn init-answers []
  (into {}
        (for [sec  (concat common-sections specific-sections)
              {:keys [id default always]} (:questions sec)]
          [id (if always true (boolean default))])))

(defn common-cols [answers]
  (for [sec common-sections
        q   (:questions sec)
        :when (get answers (:id q))]
    q))

(defn specific-cols [answers type-id]
  (for [sec specific-sections
        :when (= (:for sec) type-id)
        q    (:questions sec)
        :when (get answers (:id q))]
    q))

(defn cols-for-type [answers type-id]
  (concat (common-cols answers) (specific-cols answers type-id)))

;; ── Excel generation ─────────────────────────────────────────────────────────
(defn add-sheet! [wb answers type-id]
  (let [type-info   (type-by-id type-id)
        sheet-name  (:short type-info)
        cols        (vec (cols-for-type answers type-id))
        hdrs        (mapv :col cols)
        rows        (into [hdrs] (repeat 20 (vec (repeat (count hdrs) ""))))
        ws          (XLSX/utils.aoa_to_sheet (clj->js rows))
        widths      (mapv #(clj->js {:wch (max 18 (+ 2 (count (:col %))))}) cols)]

    (aset ws "!cols" (clj->js widths))

    ;; Dropdown pour "État de fonctionnement"
    (when-let [etat-idx (first (keep-indexed #(when (= (:col %2) "État de fonctionnement") %1) cols))]
      (let [col-letter (XLSX/utils.encode_col etat-idx)
            sqref      (str col-letter "2:" col-letter "21")
            dv         (js-obj)]
        (aset dv sqref #js{:type         "List"
                           :formula1     "\"Bon,Moyen,Mauvais,Hors service\""
                           :sqref        sqref
                           :showDropDown false})
        (aset ws "!datavalidation" dv)))

    (XLSX/utils.book_append_sheet wb ws sheet-name)))

(defn generate-excel! [answers types]
  (let [wb (XLSX/utils.book_new)]
    (doseq [t (map :id (filter #(types (:id %)) equipment-types))]
      (add-sheet! wb answers t))
    (XLSX/writeFile wb "registre-equipements.xlsx")))

;; ── Components ────────────────────────────────────────────────────────────────
(defn progress-bar [current total]
  [:div.progress-wrap
   [:div.progress-bar {:style {:width (str (Math/round (* 100 (/ current total))) "%")}}]])

(defn welcome-screen []
  [:div.screen.welcome
   [:img {:src "logo.svg" :class "big-logo"}]
   [:h1 "Configurez votre registre d'équipements"]
   [:p.lead "Répondez aux questions pour générer un fichier Excel personnalisé,
             avec un onglet par famille d'équipement."]
   [:div.features
    [:div.feat [:span "✅"] [:span "Questions communes + spécifiques par famille"]]
    [:div.feat [:span "📊"] [:span "1 onglet Excel par famille d'équipement"]]
    [:div.feat [:span "▾"]  [:span "Liste déroulante pour l'état de fonctionnement"]]]
   [:button.btn-primary
    {:on-click #(swap! state assoc :step :types :answers (init-answers))}
    "Commencer →"]])

(defn type-selection []
  (let [selected (:types @state)]
    [:div.screen
     [:div.screen-header
      [:h2 "Familles d'équipements"]
      [:p "Sélectionnez toutes les familles présentes dans votre parc — un onglet sera créé pour chacune"]]
     [:div.types-grid
      (for [{:keys [id label icon]} equipment-types]
        [:div.type-card
         {:key      (name id)
          :class    (when (selected id) "selected")
          :on-click #(swap! state update :types
                            (fn [t] (if (t id) (disj t id) (conj t id))))}
         [:div.type-icon icon]
         [:div.type-label label]
         (when (selected id) [:div.type-check "✓"])])]
     [:div.nav-row
      [:button.btn-secondary {:on-click #(swap! state assoc :step :welcome)} "← Retour"]
      [:button.btn-primary
       {:disabled (empty? selected)
        :on-click #(swap! state assoc :step :questions :section-idx 0)}
       (str "Continuer (" (count selected) " famille(s)) →")]]]))

(defn question-row [q]
  (let [ans (get (:answers @state) (:id q))]
    [:div.q-row {:class (when (:always q) "always")}
     [:div.q-text
      (if (:always q)
        [:<> [:strong (:col q)] " — toujours inclus"]
        (str "Inclure : " (:col q) " ?"))
      (when (:q q) [:span.q-hint (str " — " (:q q))])]
     (if (:always q)
       [:div.q-badge "✓ Inclus"]
       [:div.toggle-wrap
        [:button.toggle
         {:class    (when ans "active-yes")
          :on-click #(swap! state assoc-in [:answers (:id q)] true)}
         "Oui"]
        [:button.toggle
         {:class    (when-not ans "active-no")
          :on-click #(swap! state assoc-in [:answers (:id q)] false)}
         "Non"]])]))

(defn questions-screen []
  (let [st         @state
        all-secs   (all-visible-sections (:types st))
        total      (count all-secs)
        idx        (:section-idx st)
        sec        (nth all-secs idx)
        qs         (:questions sec)
        all-on?    (every? #(or (:always %) (get (:answers st) (:id %))) qs)
        is-specific? (boolean (:for sec))]
    [:div.screen
     [progress-bar (inc idx) total]
     [:div.section-nav-info
      [:span.sec-count (str "Section " (inc idx) " / " total)]
      [:span.sec-name (str (:icon sec) " " (:title sec))
       (when is-specific?
         [:span.sec-tag "spécifique"])]]

     [:div.section-card
      [:div.sec-header
       [:div.sec-icon (:icon sec)]
       [:div
        [:h2 (:title sec)]
        [:p.sec-desc (:desc sec)]]
       [:button.btn-toggle-all
        {:on-click #(doseq [{:keys [id always]} qs]
                     (when-not always
                       (swap! state assoc-in [:answers id] (not all-on?))))}
        (if all-on? "Tout décocher" "Tout cocher")]]

      [:div.questions-list
       (for [q qs] ^{:key (name (:id q))} [question-row q])]]

     (when is-specific?
       [:div.common-note
        "💡 Les colonnes communes (identification, localisation, contrats…) seront automatiquement ajoutées à cet onglet."])

     [:div.nav-row
      [:button.btn-secondary
       {:on-click #(if (zero? idx)
                     (swap! state assoc :step :types)
                     (swap! state update :section-idx dec))}
       "← Retour"]
      [:button.btn-primary
       {:on-click #(if (< idx (dec total))
                     (swap! state update :section-idx inc)
                     (swap! state assoc :step :summary))}
       (if (< idx (dec total)) "Suivant →" "Voir le récapitulatif →")]]]))

(defn sheet-preview [type-id answers]
  (let [type-info  (type-by-id type-id)
        c-cols     (vec (common-cols answers))
        s-cols     (vec (specific-cols answers type-id))
        all-cols   (concat c-cols s-cols)]
    [:div.sheet-preview
     [:div.sheet-tab
      [:span (:icon type-info)]
      [:span (:short type-info)]
      [:span.tab-count (str (count all-cols) " colonnes")]]
     [:div.sheet-cols
      [:div.cols-group
       [:div.cols-group-label "Communes"]
       [:div.cols-chips
        (for [c c-cols]
          [:span.col-chip-sm {:key (:id c)} (:col c)])]]
      (when (seq s-cols)
        [:div.cols-group
         [:div.cols-group-label "Spécifiques"]
         [:div.cols-chips
          (for [c s-cols]
            [:span.col-chip-sm.specific {:key (:id c)} (:col c)])]])]]))

(defn summary-screen []
  (let [st    @state
        types (:types st)
        ans   (:answers st)]
    [:div.screen
     [:div.screen-header
      [:h2 "Récapitulatif de votre registre"]
      [:p (str (count types) " onglet(s) · 20 lignes vides par onglet · liste déroulante état de fonctionnement")]]

     [:div.sheets-list
      (for [t (map :id (filter #(types (:id %)) equipment-types))]
        ^{:key (name t)} [sheet-preview t ans])]

     [:div.nav-row
      [:button.btn-secondary
       {:on-click #(swap! state assoc :step :questions :section-idx 0)}
       "← Modifier"]
      [:button.btn-download
       {:on-click #(generate-excel! ans types)}
       "⬇ Télécharger l'Excel (.xlsx)"]]]))

;; ── Root ─────────────────────────────────────────────────────────────────────
(defn app []
  [:div.app
   [:header.top-bar
    [:img {:src "logo.svg" :alt "Urbest" :class "header-logo"}]
    [:span.header-title "Générateur de registre d'équipements"]]
   [:main
    (case (:step @state)
      :welcome   [welcome-screen]
      :types     [type-selection]
      :questions [questions-screen]
      :summary   [summary-screen])]])

(defn init []
  (rdom/render [app] (.getElementById js/document "app")))
